# Copy this to ~/.codex/mobidex/.env.test for all worktrees.
# A repo-local .env.test also works for one-off overrides and is gitignored.

MOBIDEX_E2E_HOST=192.168.1.239
MOBIDEX_E2E_USER=mazdak
MOBIDEX_E2E_CWD=/Users/mazdak/Code/resq/qlaw

MOBIDEX_E2E_PORT=22
MOBIDEX_E2E_DISPLAY_NAME=Mac Home
MOBIDEX_E2E_SERVER_ID=00000000-0000-0000-0000-00000000D0C5

MOBIDEX_E2E_AUTH=private-key
MOBIDEX_E2E_PRIVATE_KEY_PATH=/Users/mazdak/.ssh/id_ed25519
# MOBIDEX_E2E_PRIVATE_KEY_PASSPHRASE=

# Password auth is also supported:
# MOBIDEX_E2E_AUTH=password
# MOBIDEX_E2E_PASSWORD=

MOBIDEX_E2E_CODEX_PATH=codex
MOBIDEX_E2E_EXECUTION_PATH=$HOME/.bun/bin:$HOME/.cargo/bin:$HOME/.local/bin:$HOME/.npm-global/bin:/opt/homebrew/opt/node@22/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:$PATH

# connection | new-session | join | visible-new-session
MOBIDEX_E2E_MODE=new-session

# project-directory is low-impact; worktree exercises the New Worktree path.
MOBIDEX_E2E_NEW_SESSION_LOCATION=project-directory

# Optional prompt assertion after a new session. Leave unset for cheaper session tests.
# MOBIDEX_E2E_PROMPT=Reply exactly: mobidex e2e smoke.
# MOBIDEX_E2E_EXPECTED_TEXT=mobidex e2e smoke

MOBIDEX_E2E_TIMEOUT=180
# MOBIDEX_SIMULATOR_ID=
